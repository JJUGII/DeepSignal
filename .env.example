# DeepSignal 환경 변수 템플릿
# 사용법: 이 파일을 복사해 프로젝트 루트에 .env 로 저장한 뒤 값을 채웁니다.
#   Windows: copy .env.example .env
#   macOS/Linux: cp .env.example .env
#
# 주의: KEY=값 # 주석 처럼 같은 줄에 주석을 쓰면 값에 주석이 섞입니다. 주석은 별도 줄에만 작성하세요.
# 주의: 실제 API 키·토큰·계좌번호는 .env 에만 두고 git 커밋·채팅 공유하지 마세요.


# ── Upbit (코인) ─────────────────────────────────────────────
# 발급: https://upbit.com/mypage/open_api_management
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=
# true = 주문·잔고 API 호출 없음(로그만). false = 실거래(아래 CRYPTO_PAPER_MODE 도 확인)
UPBIT_DRY_RUN=true


# ── Bithumb (코인, 2단계: 조회 + 지정가 주문) ───────────────
# 발급: https://www.bithumb.com/react/ucenter/open-api  (Open API 2.x API Key / Secret Key)
# 구버전 Connect Key는 v1 API 전용 — 신규 발급 키는 v2 JWT 방식입니다.
BITHUMB_API_KEY=
BITHUMB_SECRET_KEY=
# true = 주문 API 미호출(dry-run). false + CRYPTO_PAPER_MODE=false 시 실주문 가능
BITHUMB_DRY_RUN=true


# ── 코인 공통 안전 설정 ─────────────────────────────────────
# true = 모든 코인 거래소 주문 차단(페이퍼/드라이런 강제). 실거래 시 false
CRYPTO_PAPER_MODE=true
# Web UI·조회·일일계획·자동매매 러너에 사용할 거래소 (upbit | bithumb)
CRYPTO_BROKER=upbit
# true = 텔레그램 승인 없이 자동 매수·매도(위험). 기본 false 권장
CRYPTO_AUTO_EXECUTE_WITHOUT_APPROVAL=false


# ── KIS (주식, 선택) ────────────────────────────────────────
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=01
KIS_HTS_ID=
# paper = 모의투자, live = 실계좌
KIS_ENV=paper


# ── Telegram 알림 (선택) ────────────────────────────────────
DEEPSIGNAL_NOTIFY_TELEGRAM_BOT_TOKEN=
DEEPSIGNAL_NOTIFY_TELEGRAM_CHAT_ID=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=


# ── 기타 (선택) ─────────────────────────────────────────────
# WEBHOOK_URL=
# NOTIFY_ON_FAILURE=false
# MARKET_SYMBOLS=AAPL,NVDA,MSFT,GOOGL,AMZN,META
